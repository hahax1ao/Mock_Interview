# Use one key; ALIYUN_API_KEY takes precedence. Never commit real keys.
ALIYUN_API_KEY=
DASHSCOPE_API_KEY=sk-your-key-here
QWEN_REGION=cn-beijing
QWEN_WORKSPACE_ID=
QWEN_TEXT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_REALTIME_MODEL=qwen3.5-omni-flash-realtime
QWEN_VOICE=Tina
QWEN_ASR_MODEL=qwen3-asr-flash-realtime
QWEN_MATERIAL_MODEL=qwen3.5-flash
QWEN_TECHNICAL_MODEL=qwen3.5-flash
QWEN_ECONOMY_MODEL=qwen3.5-flash
QWEN_SYNTHESIS_MODEL=qwen3.5-flash
# 1-4; local accounts generally balance latency and throttling best at 2.
QWEN_REVIEW_CONCURRENCY=2
QWEN_REQUEST_TIMEOUT_MS=60000
